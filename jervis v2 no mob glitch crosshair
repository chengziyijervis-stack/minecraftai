#ds{position:fixed;inset:0;background:rgba(120,0,0,.7);display:none;flex-direction:column;align-items:center;justify-content:center;z-index:80;color:#fff}
#ds h1{font-size:56px;color:#FF4444;text-shadow:3px 3px 0 #000;margin-bottom:30px}
#ld{position:fixed;inset:0;background:#111827;display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:200;color:#fff;font-size:26px;transition:opacity .5s}

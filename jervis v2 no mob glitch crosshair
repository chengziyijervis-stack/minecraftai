// ===== Raycast =====
function vRay(ox,oy,oz,dx,dy,dz,md){
  let x=Math.floor(ox),y=Math.floor(oy),z=Math.floor(oz);
  const sx=dx>0?1:-1,sy=dy>0?1:-1,sz=dz>0?1:-1;
  const tdx=Math.abs(1/dx),tdy=Math.abs(1/dy),tdz=Math.abs(1/dz);
  let tmx=((sx>0?x+1:x)-ox)*dx,tmy=((sy>0?y+1:y)-oy)*dy,tmz=((sz>0?z+1:z)-oz)*dz;
  let fc=[0,0,0];
  for(let i=0;i<md*3;i++){
    const b=gb(x,y,z);if(b)return{x,y,z,block:b,face:fc};
    if(tmx<tmy){if(tmx<tmz){x+=sx;tmx+=tdx;fc=[-sx,0,0]}else{z+=sz;tmz+=tdz;fc=[0,0,-sz]}}
    else{if(tmy<tmz){y+=sy;tmy+=tdy;fc=[0,-sy,0]}else{z+=sz;tmz+=tdz;fc=[0,0,-sz]}}
    if(Math.min(tmx,tmy,tmz)>md)break;
  }
  return null;
}

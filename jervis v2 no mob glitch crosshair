  for(let cx=-IR;cx<=IR;cx++)for(let cz=-IR;cz<=IR;cz++){if(cx*cx+cz*cz>IR*IR)continue;genT(cx,cz);step++;bar.style.width=(step/total*100)+'%';await new Promise(r=>setTimeout(r,0))}
  for(let cx=-IR;cx<=IR;cx++)for(let cz=-IR;cz<=IR;cz++){if(cx*cx+cz*cz>IR*IR)continue;genTr(cx,cz);step++;bar.style.width=(step/total*100)+'%';await new Promise(r=>setTimeout(r,0))}
  for(let cx=-IR;cx<=IR;cx++)for(let cz=-IR;cz<=IR;cz++){if(cx*cx+cz*cz>IR*IR)continue;rebC(cx,cz);step++;bar.style.width=(step/total*100)+'%';await new Promise(r=>setTimeout(r,0))}
  for(let y=WH-1;y>=0;y--)if(gb(0,y,0)){P.y=y+1.5;break}
  inv[27]={id:BT.DIRT,count:20};inv[28]={id:BT.COBBLE,count:15};inv[29]={id:BT.PLANKS,count:10};inv[30]={id:BT.GLASS,count:8};inv[31]={id:FOOD,count:5};inv[32]={id:BT.BRICK,count:10};
  mkHB();mkInv();upSV();step++;bar.style.width='100%';await new Promise(r=>setTimeout(r,300));
  document.getElementById('ld').style.opacity='0';
  setTimeout(()=>{document.getElementById('ld').style.display='none';document.getElementById('ov').style.display='flex'},500);
  document.getElementById('pbtn').addEventListener('click',()=>{iAud();started=true;ren.domElement.requestPointerLock();document.getElementById('ov').style.display='none';document.getElementById('hotbar').style.display='flex';document.getElementById('surv').style.display='flex';document.getElementById('cd').style.display='block'});
  document.getElementById('rbtn').addEventListener('click',respawn);
  requestAnimationFrame(anim);
}

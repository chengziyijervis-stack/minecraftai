<style>
*{margin:0;padding:0;box-sizing:border-box}
body{overflow:hidden;background:#000;font-family:'VT323',monospace;user-select:none}
canvas{display:block}
#crosshair{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none;z-index:10;display:none}
#crosshair::before,#crosshair::after{content:'';position:absolute;background:#fff;mix-blend-mode:difference}
#crosshair::before{width:2px;height:22px;top:-11px;left:-1px}
#crosshair::after{width:22px;height:2px;top:-1px;left:-11px}
#hotbar{position:fixed;bottom:14px;left:50%;transform:translateX(-50%);display:none;gap:2px;z-index:10;background:rgba(0,0,0,.7);padding:4px;border:2px solid rgba(255,255,255,.12);border-radius:4px}
.hs{width:50px;height:50px;border:2px solid rgba(255,255,255,.07);border-radius:3px;display:flex;align-items:center;justify-content:center;position:relative;cursor:pointer;transition:border-color .1s,box-shadow .1s}
.hs.on{border-color:#D4A843;box-shadow:0 0 10px rgba(212,168,67,.45)}
.hs canvas{width:34px;height:34px;image-rendering:pixelated}
.hs .k{position:absolute;top:1px;left:3px;font-size:11px;color:rgba(255,255,255,.4)}
.sc{position:absolute;bottom:1px;right:3px;font-size:13px;color:#fff;text-shadow:1px 1px 1px #000}
#surv{position:fixed;bottom:72px;left:50%;transform:translateX(-50%);display:none;gap:14px;z-index:10;align-items:center}
#hp,#hg{display:flex;gap:1px}
#hp span,#hg span{font-size:15px;line-height:1}
.hf{color:#C62828}.he{color:#3a1515}.hh{color:#E57373}
.gf{color:#C17D2B}.ge{color:#3a2a10}.gh{color:#DDA04A}
#bn{position:fixed;bottom:96px;left:50%;transform:translateX(-50%);color:#fff;font-size:20px;text-shadow:2px 2px 4px rgba(0,0,0,.85);z-index:10;pointer-events:none;opacity:0;transition:opacity .25s}
#bn.s{opacity:1}
#cd{position:fixed;top:10px;left:12px;color:#fff;font-size:16px;text-shadow:1px 1px 3px rgba(0,0,0,.8);z-index:10;pointer-events:none;display:none}
#df{position:fixed;inset:0;background:rgba(180,0,0,.35);pointer-events:none;z-index:9;opacity:0;transition:opacity .12s}
#ov{position:fixed;inset:0;background:rgba(0,0,0,.88);display:none;flex-direction:column;align-items:center;justify-content:center;z-index:100;color:#fff}
#ov h1{font-size:52px;color:#D4A843;margin-bottom:24px;text-shadow:3px 3px 0 #000;letter-spacing:5px}
#ov .ct{text-align:left;font-size:17px;line-height:2.1;margin-bottom:24px;color:rgba(255,255,255,.75)}
#ov .ct span{color:#D4A843;display:inline-block;min-width:130px}
.pb{padding:12px 40px;font-size:26px;font-family:'VT323',monospace;background:#D4A843;color:#000;border:none;cursor:pointer;border-radius:4px;transition:background .2s,transform .1s}
.pb:hover{background:#E8BC57;transform:scale(1.06)}
#rh{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);color:rgba(255,255,255,.6);font-size:22px;z-index:10;pointer-events:none;display:none;text-shadow:1px 1px 3px #000}
#io{position:fixed;inset:0;background:rgba(0,0,0,.75);display:none;align-items:center;justify-content:center;z-index:50}
#ip{background:rgba(50,40,30,.95);border:3px solid rgba(255,255,255,.12);border-radius:6px;padding:12px}
